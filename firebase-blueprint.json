{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Character": {
      "title": "Character",
      "description": "A Tormenta 20 character",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "race_id": { "type": "string" },
        "class_id": { "type": "string" },
        "origin_id": { "type": "string" },
        "level": { "type": "integer" },
        "attributes_base": { "type": "object" },
        "current_hp": { "type": "integer" },
        "current_mp": { "type": "integer" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "name", "level"]
    },
    "Power": {
      "title": "Power",
      "description": "A character power",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "power_type": { "type": "string" },
        "description": { "type": "string" },
        "requirement_text": { "type": "string" }
      }
    },
    "Group": {
      "title": "Group",
      "description": "A party of characters",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "owner_id": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "invite_code": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "owner_id", "members"]
    },
    "Roll": {
      "title": "Roll",
      "description": "A dice roll result",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "character_name": { "type": "string" },
        "group_id": { "type": "string" },
        "label": { "type": "string" },
        "result": { "type": "integer" },
        "bonus": { "type": "integer" },
        "is_critical": { "type": "boolean" },
        "is_fail": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "character_name", "group_id", "result"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/characters/{characterId}": {
      "schema": "Character",
      "description": "Character documents"
    },
    "/characters/{characterId}/powers/{powerId}": {
      "schema": "Power",
      "description": "Powers assigned to a character"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Party groups"
    },
    "/rolls/{rollId}": {
      "schema": "Roll",
      "description": "Dice roll logs"
    }
  }
}
